{
  "name": "barnito",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Barnito - a World Cup 2026 prediction game for the friend group",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seed-from-openfootball.ts",
    "seed:predictions": "tsx scripts/seed-predictions.ts",
    "seed:all": "tsx scripts/seed-from-openfootball.ts && tsx scripts/seed-predictions.ts && tsx scripts/score.ts",
    "verify": "tsx scripts/verify-api.ts",
    "roster": "tsx scripts/build-roster.ts",
    "predictions": "tsx scripts/parse-predictions.ts",
    "fetch": "tsx scripts/fetch-data.ts",
    "score": "tsx scripts/score.ts",
    "update": "tsx scripts/fetch-data.ts && tsx scripts/score.ts",
    "template": "tsx scripts/make-template.ts",
    "airhorn": "tsx scripts/make-airhorn.ts"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.3",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.456.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.6.4",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
